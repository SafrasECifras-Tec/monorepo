{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gef",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    { "pattern": "gef.sociosdoagro.com.br/*", "zone_name": "sociosdoagro.com.br" }
  ],
  "env": {
    "dev": {
      "name": "socios-gef-dev",
      "routes": []
    }
  }
}
